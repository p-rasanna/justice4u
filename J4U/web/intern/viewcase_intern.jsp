<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" import="java.sql.*,com.j4u.DatabaseConfig" %> <% String iEmail=(String)session.getAttribute("iname"); if(iEmail==null){response.sendRedirect("../auth/Login.jsp");return;} String cidS=request.getParameter("cid"); if(cidS==null){response.sendRedirect("interndashboard.jsp");return;} int cid=Integer.parseInt(cidS); String title="", desc="", court="", city="", lName=""; try(Connection con=DatabaseConfig.getConnection()){ PreparedStatement ps=con.prepareStatement("SELECT c.title, c.description, c.courttype, c.city, l.name FROM casetb c JOIN intern_assignments ia ON c.cid=ia.case_id JOIN lawyer_reg l ON ia.alid=l.lid WHERE c.cid=? AND ia.intern_email=? AND ia.status='ACTIVE'"); ps.setInt(1,cid); ps.setString(2,iEmail); ResultSet rs=ps.executeQuery(); if(rs.next()){ title=rs.getString(1); desc=rs.getString(2); court=rs.getString(3); city=rs.getString(4); lName=rs.getString(5); } else { response.sendRedirect("interndashboard.jsp?msg=Access denied"); return; } %> <!DOCTYPE html> <html lang="en"> <jsp:include page="components/_head.jsp"><jsp:param name="title" value="Intern Workspace"/></jsp:include> <body class="bg-light"> <div class="container py-5"> <a href="interndashboard.jsp" class="btn btn-sm btn-outline-dark mb-4"><i class="ph ph-arrow-left"></i> Dashboard</a> <div class="panel p-5 mb-4"> <div class="d-flex justify-content-between align-items-start mb-4"> <div> <h1 class="mb-1">Case #<%=cid%>: <em><%=title%></em></h1> <span class="badge bg-gold-soft text-gold px-3 py-2 small">Active Associate Assignment</span> </div> <div class="text-end"> <p class="text-muted small mb-0">Supervising Lawyer</p> <p class=""><%=lName%></p> </div> </div> <div class="row g-4 mb-4"> <div class="col-md-4"><div class="border rounded"><p class="text-muted small mb-1 uppercase">Court</p><p class="mb-0"><%=court%></p></div></div> <div class="col-md-4"><div class="border rounded"><p class="text-muted small mb-1 uppercase">City</p><p class="mb-0"><%=city%></p></div></div> </div> <div class="p-4 bg-light rounded"><p class="text-muted small mb-2 uppercase">Case Context</p><p class="mb-0 lh-lg"><%=desc%></p></div> </div> <div class="panel p-5"> <h3 class="panel-head border-bottom-0 p-0 mb-4"><i class="ph-duotone ph-files panel-icon"></i> Case Documents</h3> <div class="table-responsive"> <table class="table align-middle"> <thead class="bg-light"><tr><th class="">File Name</th><th class="">Uploaded By</th><th class="">Date</th><th class="text-end">Action</th></tr></thead> <tbody> <% ps=con.prepareStatement("SELECT file_name, file_path, uploader_email, uploaded_at FROM case_documents WHERE case_id=? ORDER BY uploaded_at DESC"); ps.setInt(1,cid); rs=ps.executeQuery(); while(rs.next()){ %> <tr> <td class=""><%=rs.getString(1)%></td><td class=""><%=rs.getString(3)%></td> <td class="text-muted small"><%=rs.getString(4)%></td> <td class="text-end"><a href="<%=rs.getString(2)%>" target="_blank" class="btn btn-sm btn-dark px-3">View</a></td> </tr> <% } %> </tbody> </table> </div> <div class="mt-5 p-4 border border-dashed rounded text-center"> <p class="text-muted small mb-3">Found new evidence or completed research?</p> <a href="uploadInternWork.jsp?task_id=0&cid=<%=cid%>" class="btn btn-outline-dark"><i class="ph ph-upload-simple me-2"></i> Submit Research Deliverable</a> </div> </div> </div> </body> </html> <% }catch(Exception e){out.print(e.getMessage());} %> 