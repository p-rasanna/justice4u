RewriteEngine On

# Keep real files/folders untouched.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Prevent rewrite loops on internal rewrites.
RewriteCond %{ENV:REDIRECT_STATUS} !^$
RewriteRule ^ - [L]

# Match both root and nested relative paths, e.g.:
# /Login.html and /client/Login.html -> /auth/Login.html
# /viewcases.jsp and /lawyer/viewcases.jsp -> /lawyer/viewcases.jsp

# Auth
RewriteRule ^(?:.*/)?Login\.html$ auth/Login.html [L,NC]
RewriteRule ^(?:.*/)?Login\.jsp$ auth/Login.jsp [L,NC]
RewriteRule ^(?:.*/)?Lawyer_login\.html$ auth/Lawyer_login.html [L,NC]
RewriteRule ^(?:.*/)?Lawyer_login\.jsp$ auth/Lawyer_login.jsp [L,NC]
RewriteRule ^(?:.*/)?cust_login\.html$ auth/cust_login.html [L,NC]
RewriteRule ^(?:.*/)?cust_login\.jsp$ auth/cust_login.jsp [L,NC]
RewriteRule ^(?:.*/)?internlogin\.html$ auth/internlogin.html [L,NC]
RewriteRule ^(?:.*/)?internlogin\.jsp$ auth/internlogin.jsp [L,NC]
RewriteRule ^(?:.*/)?forgot_password\.html$ auth/forgot_password.html [L,NC]
RewriteRule ^(?:.*/)?final_password_reset\.jsp$ auth/final_password_reset.jsp [L,NC]
RewriteRule ^(?:.*/)?reset_password_fixed\.jsp$ auth/reset_password_fixed.jsp [L,NC]
RewriteRule ^(?:.*/)?force_reset_password\.jsp$ auth/force_reset_password.jsp [L,NC]
RewriteRule ^(?:.*/)?reset_client_password\.jsp$ auth/reset_client_password.jsp [L,NC]
RewriteRule ^(?:.*/)?verification_pending\.jsp$ auth/verification_pending.jsp [L,NC]
RewriteRule ^(?:.*/)?lawyer_registration_success\.jsp$ auth/lawyer_registration_success.jsp [L,NC]
RewriteRule ^(?:.*/)?Lawyerlogin\.html$ auth/Lawyer_login.html [L,NC]
RewriteRule ^(?:.*/)?Register\.html$ client/customer.html [L,NC]

# Admin
RewriteRule ^(?:.*/)?admindashboard\.jsp$ admin/admindashboard.jsp [L,NC]
RewriteRule ^(?:.*/)?viewlawyers\.jsp$ admin/viewlawyers.jsp [L,NC]
RewriteRule ^(?:.*/)?viewcustomers\.jsp$ admin/viewcustomers.jsp [L,NC]
RewriteRule ^(?:.*/)?viewinterns\.jsp$ admin/viewinterns.jsp [L,NC]
RewriteRule ^(?:.*/)?allotlawyer\.jsp$ admin/allotlawyer.jsp [L,NC]
RewriteRule ^(?:.*/)?allotlawyerdone\.jsp$ admin/allotlawyerdone.jsp [L,NC]
RewriteRule ^(?:.*/)?approve_lawyer\.jsp$ admin/approve_lawyer.jsp [L,NC]
RewriteRule ^(?:.*/)?approvel\.jsp$ admin/approvel.jsp [L,NC]
RewriteRule ^(?:.*/)?rejectl\.jsp$ admin/rejectl.jsp [L,NC]
RewriteRule ^(?:.*/)?approvei\.jsp$ admin/approvei.jsp [L,NC]
RewriteRule ^(?:.*/)?rejecti\.jsp$ admin/rejecti.jsp [L,NC]
RewriteRule ^(?:.*/)?approvecustomer\.jsp$ admin/approvecustomer.jsp [L,NC]
RewriteRule ^(?:.*/)?rejectcustomer\.jsp$ admin/rejectcustomer.jsp [L,NC]
RewriteRule ^(?:.*/)?viewapprovedlawyers\.jsp$ admin/viewapprovedlawyers.jsp [L,NC]
RewriteRule ^(?:.*/)?viewapprovedinterns\.jsp$ admin/viewapprovedinterns.jsp [L,NC]
RewriteRule ^(?:.*/)?viewlawyeri\.jsp$ admin/viewlawyeri.jsp [L,NC]
RewriteRule ^(?:.*/)?viewinternl\.jsp$ admin/viewinternl.jsp [L,NC]
RewriteRule ^(?:.*/)?viewdisl\.jsp$ admin/viewdisl.jsp [L,NC]
RewriteRule ^(?:.*/)?verifylawyerdoc\.jsp$ admin/verifylawyerdoc.jsp [L,NC]
RewriteRule ^(?:.*/)?viewcusdet\.jsp$ admin/viewcusdet.jsp [L,NC]
RewriteRule ^(?:.*/)?viewlawdet\.jsp$ admin/viewlawdet.jsp [L,NC]
RewriteRule ^(?:.*/)?viewdisc\.jsp$ admin/viewdisc.jsp [L,NC]
RewriteRule ^(?:.*/)?security_audit_report\.jsp$ admin/security_audit_report.jsp [L,NC]
RewriteRule ^(?:.*/)?lddone\.jsp$ admin/lddone.jsp [L,NC]
RewriteRule ^(?:.*/)?cddone\.jsp$ admin/cddone.jsp [L,NC]
RewriteRule ^(?:.*/)?asignout\.jsp$ admin/asignout.jsp [L,NC]
RewriteRule ^(?:.*/)?desc_cust\.jsp$ admin/desc_cust.jsp [L,NC]
RewriteRule ^(?:.*/)?migrate_passwords\.jsp$ admin/migrate_passwords.jsp [L,NC]
RewriteRule ^(?:.*/)?migrate_task_schema\.jsp$ admin/migrate_task_schema.jsp [L,NC]
RewriteRule ^(?:.*/)?setup_intern_db\.jsp$ admin/setup_intern_db.jsp [L,NC]
RewriteRule ^(?:.*/)?sync_cases\.jsp$ admin/sync_cases.jsp [L,NC]

# Lawyer
RewriteRule ^(?:.*/)?Lawyerdashboard\.jsp$ lawyer/Lawyerdashboard.jsp [L,NC]
RewriteRule ^(?:.*/)?lawyerdashboard\.jsp$ lawyer/Lawyerdashboard.jsp [L,NC]
RewriteRule ^(?:.*/)?case\.jsp$ lawyer/case.jsp [L,NC]
RewriteRule ^(?:.*/)?lawyerprofile\.jsp$ lawyer/lawyerprofile.jsp [L,NC]
RewriteRule ^(?:.*/)?lawyerprofile\.html$ lawyer/lawyerprofile.html [L,NC]
RewriteRule ^(?:.*/)?lawyer_remarks\.jsp$ lawyer/lawyer_remarks.jsp [L,NC]
RewriteRule ^(?:.*/)?case_timeline\.jsp$ lawyer/case_timeline.jsp [L,NC]
RewriteRule ^(?:.*/)?manage_hearings\.jsp$ lawyer/manage_hearings.jsp [L,NC]
RewriteRule ^(?:.*/)?add_case_note\.jsp$ lawyer/add_case_note.jsp [L,NC]
RewriteRule ^(?:.*/)?acceptcase\.jsp$ lawyer/acceptcase.jsp [L,NC]
RewriteRule ^(?:.*/)?rejectcase\.jsp$ lawyer/rejectcase.jsp [L,NC]
RewriteRule ^(?:.*/)?closecase\.jsp$ lawyer/closecase.jsp [L,NC]
RewriteRule ^(?:.*/)?update_case_lawyer\.jsp$ lawyer/update_case_lawyer.jsp [L,NC]
RewriteRule ^(?:.*/)?viewlawyerdocuments\.jsp$ lawyer/viewlawyerdocuments.jsp [L,NC]
RewriteRule ^(?:.*/)?viewcases\.jsp$ lawyer/viewcases.jsp [L,NC]
RewriteRule ^(?:.*/)?viewcase\.jsp$ lawyer/viewcase.jsp [L,NC]
RewriteRule ^(?:.*/)?lsignout\.jsp$ lawyer/lsignout.jsp [L,NC]
RewriteRule ^(?:.*/)?findlawyer\.jsp$ lawyer/findlawyer.jsp [L,NC]

# Client
RewriteRule ^(?:.*/)?customerdashboard\.jsp$ client/customerdashboard.jsp [L,NC]
RewriteRule ^(?:.*/)?clientdashboard_manual\.jsp$ client/clientdashboard_manual.jsp [L,NC]
RewriteRule ^(?:.*/)?customer\.html$ client/customer.html [L,NC]
RewriteRule ^(?:.*/)?customer\.jsp$ client/customer.jsp [L,NC]
RewriteRule ^(?:.*/)?client_case_details\.jsp$ client/client_case_details.jsp [L,NC]
RewriteRule ^(?:.*/)?client_viewcases\.jsp$ client/client_viewcases.jsp [L,NC]
RewriteRule ^(?:.*/)?client_chat\.jsp$ client/client_chat.jsp [L,NC]
RewriteRule ^(?:.*/)?client_chat_cases\.jsp$ client/client_chat_cases.jsp [L,NC]
RewriteRule ^(?:.*/)?requestlawyer\.jsp$ client/requestlawyer.jsp [L,NC]
RewriteRule ^(?:.*/)?csignout\.jsp$ client/csignout.jsp [L,NC]
