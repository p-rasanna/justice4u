# Intern
RewriteRule ^(?:.*/)?interndashboard\.jsp$ intern/interndashboard.jsp [L,NC]
RewriteRule ^(?:.*/)?intern\.jsp$ intern/intern.jsp [L,NC]
RewriteRule ^(?:.*/)?assign_intern_case\.jsp$ intern/assign_intern_case.jsp [L,NC]
RewriteRule ^(?:.*/)?assign_task\.jsp$ intern/assign_task.jsp [L,NC]
RewriteRule ^(?:.*/)?process_assign_intern\.jsp$ intern/process_assign_intern.jsp [L,NC]
RewriteRule ^(?:.*/)?uploadInternWork\.jsp$ intern/uploadInternWork.jsp [L,NC]
RewriteRule ^(?:.*/)?viewcase_intern\.jsp$ intern/viewcase_intern.jsp [L,NC]
RewriteRule ^(?:.*/)?isignout\.jsp$ intern/isignout.jsp [L,NC]

# Shared
RewriteRule ^(?:.*/)?db_connection\.jsp$ shared/db_connection.jsp [L,NC]
RewriteRule ^(?:.*/)?csrf_token\.jsp$ shared/csrf_token.jsp [L,NC]
RewriteRule ^(?:.*/)?session_validator\.jsp$ shared/session_validator.jsp [L,NC]
RewriteRule ^(?:.*/)?error\.jsp$ shared/error.jsp [L,NC]
RewriteRule ^(?:.*/)?404\.jsp$ shared/404.jsp [L,NC]
RewriteRule ^(?:.*/)?accessDenied\.jsp$ shared/accessDenied.jsp [L,NC]
RewriteRule ^(?:.*/)?styles\.css$ shared/styles.css [L,NC]
RewriteRule ^(?:.*/)?script\.js$ shared/script.js [L,NC]
RewriteRule ^(?:.*/)?main\.js$ shared/main.js [L,NC]
RewriteRule ^(?:.*/)?justice4u-tokens\.css$ shared/justice4u-tokens.css [L,NC]
RewriteRule ^(?:.*/)?dbconfig\.properties$ shared/dbconfig.properties [L,NC]
RewriteRule ^(?:.*/)?path_finder\.jsp$ shared/path_finder.jsp [L,NC]
RewriteRule ^(?:.*/)?chat\.jsp$ shared/chat.jsp [L,NC]
RewriteRule ^(?:.*/)?send_message\.jsp$ shared/send_message.jsp [L,NC]
RewriteRule ^(?:.*/)?get_new_messages\.jsp$ shared/get_new_messages.jsp [L,NC]
RewriteRule ^(?:.*/)?download_case_doc\.jsp$ shared/download_case_doc.jsp [L,NC]
RewriteRule ^(?:.*/)?view_case_documents\.jsp$ shared/view_case_documents.jsp [L,NC]
RewriteRule ^(?:.*/)?upload_case_doc\.jsp$ shared/upload_case_doc.jsp [L,NC]
RewriteRule ^(?:.*/)?enhanced_document_upload\.jsp$ shared/enhanced_document_upload.jsp [L,NC]
RewriteRule ^(?:.*/)?disc\.jsp$ shared/disc.jsp [L,NC]
RewriteRule ^(?:.*/)?disf\.jsp$ shared/disf.jsp [L,NC]

# Landing/public
RewriteRule ^(?:.*/)?Home\.html$ landing/Home.html [L,NC]
RewriteRule ^(?:.*/)?Lawyer\.html$ landing/Lawyer.html [L,NC]
RewriteRule ^(?:.*/)?Lawyer\.jsp$ landing/Lawyer.jsp [L,NC]
RewriteRule ^(?:.*/)?role_select\.html$ landing/role_select.html [L,NC]
RewriteRule ^(?:.*/)?about\.html$ landing/about.html [L,NC]
RewriteRule ^(?:.*/)?get-started\.html$ landing/get-started.html [L,NC]
RewriteRule ^(?:.*/)?privacy\.html$ landing/privacy.html [L,NC]
RewriteRule ^(?:.*/)?terms\.html$ landing/terms.html [L,NC]
RewriteRule ^(?:.*/)?security\.html$ landing/security.html [L,NC]
RewriteRule ^(?:.*/)?design-system\.html$ landing/design-system.html [L,NC]
RewriteRule ^(?:.*/)?lawyerdashboard\.html$ landing/lawyerdashboard.html [L,NC]
RewriteRule ^(?:.*/)?header\.html$ landing/header.html [L,NC]
RewriteRule ^(?:.*/)?body\.html$ landing/body.html [L,NC]
RewriteRule ^(?:.*/)?findlawyer\.html$ landing/findlawyer.html [L,NC]

DirectoryIndex landing/Home.html
ErrorDocument 404 /shared/404.jsp
ErrorDocument 500 /shared/error.jsp
