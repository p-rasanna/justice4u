<%@page import="java.sql.*"%>
<!DOCTYPE html>
<html lang="en">
<head>
    <title>Lawyer Registration</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <style type="text/css">
        * {
            padding: 0;
            margin: 0;
            box-sizing: border-box;
        }

        body {
            background-image: url('t8.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Arial', sans-serif;
        }

        .registration-container {
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 15px;
            padding: 30px;
            width: 100%;
            max-width: 900px;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
            margin: 20px;
        }

        .registration-container h2 {
            color: #000;
            text-align: center;
            margin-bottom: 30px;
            font-size: 28px;
            font-weight: bold;
        }

        .form-group label {
            font-weight: bold;
            color: #000;
            font-size: 16px;
        }

        .form-control {
            border-radius: 10px;
            border: 2px solid #007700;
            padding: 10px;
            transition: border-color 0.3s;
            background: rgba(255, 255, 255, 0.8);
        }

        .form-control:focus {
            border-color: #1A3C34;
            box-shadow: 0 0 5px rgba(26, 60, 52, 0.5);
        }

        .error {
            color: #ff4d4d;
            font-size: 12px;
            display: block;
            margin-top: 5px;
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
        }

        .btn-primary {
            background: #2E5C54;
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-size: 18px;
            transition: background-color 0.3s ease, transform 0.2s ease;
        }

        .btn-primary:hover {
            background: #3D7068;
            transform: translateY(-2px);
        }

        .btn-danger {
            background: #e0e0e0;
            color: #333;
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-size: 18px;
            transition: background-color 0.3s ease, transform 0.2s ease;
        }

        .btn-danger:hover {
            background: #d0d0d0;
            transform: translateY(-2px);
        }

        .scanner-image {
            display: block;
            margin: 10px auto;
            max-width: 200px;
            height: auto;
            border: 2px solid #fff;
            border-radius: 5px;
        }

        .checkbox-group {
            text-align: center;
            margin: 10px 0;
        }

        .checkbox-group label {
            color: #fff;
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
        }

        @media (max-width: 768px) {
            .registration-container {
                padding: 20px;
                margin: 10px;
            }

            .btn-primary, .btn-danger {
                font-size: 16px;
                padding: 10px;
            }

            .scanner-image {
                max-width: 150px;
            }
        }
    </style>
</head>
<body>
    <div class="registration-container">
        <h2>Lawyer Discussion</h2>
        <form action="lddone.jsp" onsubmit="return validateForm()">
            <div class="row">
                <div class="col-md-6 form-group">
                    <label for="txtname">Title</label>
                    <input type="text" name="title" id="txtname"  class="form-control" required>
                    <span id="nameError" class="error"></span>
                </div>
                <div class="col-md-6 form-group">
                    <label for="txtemail">CurrentDate</label>
                    <input type="date" name="cdate" id="txtemail"  class="form-control">
                    <span id="emailError" class="error"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 form-group">
                    <label for="txtpass">Description</label>
                            <textarea name="descr" id="descr" class="form-control" rows="3"></textarea>
                    <span id="passError" class="error"></span>
                </div>
                <div class="col-md-6 form-group">
                    <label for="txtcpass">Customer Email</label>
                    <select name="cname" class="form-control" required>
                        <%
                try
                {
                    Class.forName("com.mysql.jdbc.Driver");
        Connection con=DriverManager.getConnection("jdbc:mysql://localhost:3306/j4u","root","");
        Statement st=con.createStatement();
        String id="'"+(String)session.getAttribute("lname")+"'";
        ResultSet rs=st.executeQuery("select distinct(cname) from allotlawyer where lname="+id+"");
        while(rs.next())
        {
            out.println("<option>"+rs.getString(1));
        }
                }
                catch(Exception e)
                {
                    out.println(e);
                }
                 %>   </select>
                    <span id="cpassError" class="error"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 form-group">
                    <label for="txtdob">Lawyer Email</label>
                    <input type="text" name="lemail" id="txtdob" value="<%=(String)session.getAttribute("lname")%>" class="form-control">
                    <span id="dobError" class="error"></span>
                </div>
                
            </div>

            <div class="row">
                <div class="col-md-12 text-center">
                    <input type="submit" class="btn btn-primary btn-lg" value="Submit">
                    <a href="Lawyerdashboard.jsp" class="btn btn-danger btn-lg">Dashboard</a>
                </div>
            </div>
        </form>
    </div>


</body>
</html>
