<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" import="java.sql.*,com.j4u.DatabaseConfig" %> <% String adminEmail=(String)session.getAttribute("aname"); if(adminEmail==null){response.sendRedirect("../auth/Login.jsp");return;} String cid=request.getParameter("id"), cml=request.getParameter("cemail"), cName="", cEmail="", title="General", desc="", date=new java.text.SimpleDateFormat("yyyy-MM-dd").format(new java.util.Date()), court="General", city=""; boolean isD=(cid==null); if(cid==null && cml==null){response.sendRedirect("viewcases.jsp");return;} try(Connection con=DatabaseConfig.getConnection()){ if(!isD){ try(PreparedStatement ps=con.prepareStatement("SELECT * FROM casetb WHERE cid=?")){ ps.setInt(1,Integer.parseInt(cid)); ResultSet rs=ps.executeQuery(); if(rs.next()){ cName=rs.getString(2); title=rs.getString(3); desc=rs.getString(4); date=rs.getString(5); court=rs.getString(6); city=rs.getString(7); cEmail=rs.getString(11); } } } else { cEmail=cml; try(PreparedStatement ps=con.prepareStatement("SELECT cname FROM cust_reg WHERE email=?")){ ps.setString(1,cEmail); ResultSet rs=ps.executeQuery(); if(rs.next()) cName=rs.getString(1); } } }catch(Exception e){ response.sendRedirect("viewcases.jsp?error=Data fetch failed"); return; } %> <!DOCTYPE html> <html lang="en"> <jsp:include page="components/_head.jsp"><jsp:param name="title" value="Assign Counsel"/></jsp:include> <body> <div class="app-layout"> <jsp:include page="components/_sidebar.jsp" /> <main class="main-content"> <jsp:include page="components/_topbar.jsp"><jsp:param name="title" value="Case"/><jsp:param name="subtitle" value="Allotment"/></jsp:include> <div class="p-5"> <form class="panel p-5" action="allotlawyerdone.jsp" method="post"> <input type="hidden" name="isDirect" value="<%=isD%>"> <input type="hidden" name="currentdate" value="<%=date%>"> <div class="row g-5"> <div class="col-md-6 border-end border-light pr-md-5"> < class="mb-4 text-gold">Case Details</> <div class="mb-3"><label class="small text-muted mb-1">Case / Client ID</label><input type="text" class="form-control bg-light" name="customerid" value="<%=cid!=null?cid:"NEW"%>" readonly></div> <div class="mb-3"><label class="small text-muted mb-1">Client Name</label><input type="text" class="form-control bg-light" name="customername" value="<%=cName%>" readonly></div> <div class="mb-3"><label class="small text-muted mb-1">Case Title</label><input type="text" class="form-control" name="title" value="<%=title%>" <%=isD?"":"readonly"%>></div> <div class="mb-3"><label class="small text-muted mb-1">Description</label><textarea class="form-control" name="description" rows="4" <%=isD?"":"readonly"%>><%=desc%></textarea></div> </div> <div class="col-md-6"> < class="mb-4 text-gold">Allotment</> <div class="mb-3"><label class="small text-muted mb-1">Client Email</label><input type="text" class="form-control bg-light" name="cname" value="<%=cEmail%>" readonly></div> <div class="row g-3 mb-4"> <div class="col-6"><label class="small text-muted mb-1">Court Type</label><input type="text" class="form-control" name="courtType" value="<%=court%>" <%=isD?"":"readonly"%>></div> <div class="col-6"><label class="small text-muted mb-1">City</label><input type="text" class="form-control" name="city" value="<%=city%>" <%=isD?"":"readonly"%>></div> </div> <div class="mb-4"> <label class="small text-muted mb-1">Assign Lawyer</label> <select name="lname" class="form-select border-dark" required> <option value="">Select Counsel...</option> <% try(Connection con2=DatabaseConfig.getConnection()){ ResultSet rl=con2.createStatement().executeQuery("SELECT email, lname FROM lawyer_reg WHERE status='APPROVED' OR flag=1"); while(rl.next()){ %><option value="<%=rl.getString(1)%>"><%=rl.getString(2)%> (<%=rl.getString(1)%>)</option><% } } catch(Exception e){} %> </select> <small class="text-muted mt-2 d-block"><i class="ph-fill ph-info"></i> Only active, verified lawyers are listed.</small> </div> <div class="d-flex gap-3 pt-3 mt-auto"> <button type="submit" class="btn btn-dark flex-grow-1">Confirm Assignment</button> <a href="admindashboard.jsp" class="btn btn-outline-dark">Cancel</a> </div> </div> </div> </form> </div> </main> </div> </body> </html> 